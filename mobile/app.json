{
  "expo": {
    "name": "EGOS",
    "slug": "egos-colombia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.egoscolombia.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "EGOS necesita acceso a la cámara para el probador virtual de ropa.",
        "NSPhotoLibraryUsageDescription": "EGOS necesita acceso a tus fotos para el probador virtual de ropa.",
        "NSFaceIDUsageDescription": "EGOS usa Face ID para proteger tu cuenta."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.egoscolombia.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "egos",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "egos-colombia"
      }
    }
  }
}
