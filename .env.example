# ============================================
# EGOS E-Commerce — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitees el archivo .env real
# ============================================

# Puertos
AUTH_PORT=3011
CATALOG_PORT=3002
TRANSACTION_PORT=3003
CREDIT_PORT=3008
LOGISTICS_PORT=3009
GATEWAY_PORT=3000
FRONTEND_PORT=3005
NODE_ENV=development

# JWT — genera uno seguro con: openssl rand -hex 64
JWT_SECRETO=<tu_jwt_secreto_seguro>

# PostgreSQL (Neon u otro proveedor)
POSTGRES_AUTH_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require
POSTGRES_TRANSACTION_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require
POSTGRES_MARKETING_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require
POSTGRES_CREDIT_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require
POSTGRES_FACTURACION_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require
POSTGRES_CONTABILIDAD_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require

# ePayco
EPAYCO_P_CUST_ID=<tu_customer_id>
EPAYCO_P_KEY=<tu_p_key>
EPAYCO_PUBLIC_KEY=<tu_public_key>
EPAYCO_PRIVATE_KEY=<tu_private_key>
EPAYCO_TEST=true

# MongoDB Atlas
MONGODB_CATALOG_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_SOCIAL_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_AI_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Cloudinary
CLOUDINARY_CLOUD_NAME=<tu_cloud_name>
CLOUDINARY_API_KEY=<tu_api_key>
CLOUDINARY_API_SECRET=<tu_api_secret>

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<tu_correo@gmail.com>
SMTP_PASS=<tu_app_password>
SMTP_USER_VENTAS=<ventas@tudominio.com>
SMTP_PASS_VENTAS=<app_password_ventas>

# AI / DeepSeek
AI_GATEWAY_API_KEY=<tu_deepseek_api_key>
REPLICATE_API_TOKEN=<tu_replicate_token>
HUGGINGFACE_TOKEN=<tu_hf_token>

# Google Cloud (opcional)
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_REGION=
