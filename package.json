{
  "name": "egos-ecommerce",
  "version": "1.0.0",
  "description": "EGOS E-Commerce — Microservicios en GKE",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:e2e": "jest tests/e2e --verbose",
    "test:coverage": "jest --coverage",
    "k8s:apply": "kubectl apply -f k8s/secrets/secrets.yaml && kubectl apply -f k8s/deployments/all-services.yaml && kubectl apply -f k8s/ingress/ && kubectl apply -f k8s/autoscaling/hpa.yaml",
    "k8s:delete": "kubectl delete -f k8s/deployments/all-services.yaml",
    "k8s:status": "kubectl get pods -n egos",
    "k8s:logs": "kubectl logs -f -l app=gateway -n egos"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^5.1.0",
    "mongodb": "^6.3.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": ["ecommerce", "microservicios", "gke", "kubernetes"],
  "author": "Jose Fernando Vertel",
  "license": "MIT"
}